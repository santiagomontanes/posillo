{
  "name": "sistetecni-pos-electron",
  "version": "1.0.1",
  "description": "POS offline para Sistetecni (Electron + React + SQLite)",
  "main": "dist/electron/app/electron/main.js",
  "author": "Sistetecni",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --config app/renderer/vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && npm run rebuild:native && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --config app/renderer/vite.config.ts",
    "build:electron": "node -e \"require('fs').rmSync('dist/electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json",
    "lint": "eslint . --ext .ts,.tsx",
    "package": "npm run build && npm run rebuild:native && electron-builder --win nsis",
    "rebuild:native": "npx electron-rebuild -f -w better-sqlite3",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "build": {
    "appId": "com.sistetecni.pos",
    "productName": "Sistetecni POS",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "database/**/*",
      "package.json"
    ],
    
    "publish": [
      {
        "provider": "github",
        "owner": "santiagomontanes",
        "repo": "posillo"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "SistetecniPOS-Setup-${version}.exe",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sistetecni POS"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.4.8",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.18.2",
    "pdfkit": "^0.16.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "serialport": "^13.0.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@types/pdfkit": "^0.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "wait-on": "^8.0.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}