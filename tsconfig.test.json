{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": [
      "node",
      "jest"
    ],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*.ts",
    "app/electron/**/*.ts",
    "shared/**/*.ts"
  ]
}
